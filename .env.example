# Copy this file to .env and adjust values for your environment.
# Every variable below has a working default (see config.py), so an
# empty .env -- or no .env at all -- is perfectly valid for local dev.

# --- Embedding model ---
# BGE-M3 self-hosted via sentence-transformers. Change EMBEDDING_DIMENSION
# too if you ever switch to a model with a different vector size.
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# --- LLM endpoint ---
# Defaults target a local Ollama server (no auth needed).
# Default model picked for CPU-only, ~8GB RAM machines: Qwen3 4B is a
# strong instruction-follower at a small memory footprint. Note that
# Ollama and the embedding model (BGE-M3, ~2.2GB) run *concurrently*,
# not one after another -- on an 8GB machine, close other heavy apps
# while running the pipeline. Step up to a bigger model (e.g. qwen3:8b,
# mistral:7b) if you have more RAM or a GPU; see llm/README.md.
#
# For GCP/production, point LLM_BASE_URL at your Cloud Run vLLM service
# and wire up an auth_header_provider in code (see llm/README.md) --
# there is no environment variable for GCP credentials, they should
# never be stored as a plain string.
LLM_BASE_URL=http://localhost:11434/v1
# Qwen3 (qwen3:4b) was tried first and dropped: it defaults to an
# internal reasoning trace before every answer that could not be
# reliably disabled (neither "/no_think" in the prompt nor Ollama's
# native "think": false parameter worked), adding 20-40s+ of pure
# overhead per question on CPU. Llama 3.2 3B has no such behavior and
# answers a simple prompt in ~13s on the same CPU-only hardware.
LLM_MODEL=llama3.2:3b
# CPU-only inference (no GPU) can genuinely take over a minute for a
# full answer. Raise this further if you still see ReadTimeout errors.
LLM_TIMEOUT_SECONDS=180
# Left available in case a future model choice reintroduces a
# Qwen3-style reasoning trace -- confirmed NOT reliable in practice
# (see llm/prompt.py). Not needed for the current default model.
DISABLE_LLM_THINKING=false

# --- Storage paths ---
PAPERS_DIR=data/papers
INDEX_DIR=data/index

# --- Chunking ---
CHUNK_SIZE=200
CHUNK_OVERLAP=40

# --- Indexing ---
# Checkpoint the FAISS index every N processed files, so an
# interruption (Ctrl+C, crash, closed laptop) never loses more than
# this many files of embedding work. 0 disables checkpointing.
SAVE_EVERY=10

# --- Retrieval ---
TOP_K=5
